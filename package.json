{
  "name": "solana-compat-pilot",
  "version": "0.1.2",
  "private": true,
  "description": "Conservative Codemod/JSSG workflow for migrating @solana/web3.js v1 projects onto the Solana compat bridge.",
  "type": "module",
  "scripts": {
    "migrate": "node ./scripts/migration-pipeline.mjs",
    "test": "npm run test:jssg && npm run test:pipeline",
    "test:jssg": "npx codemod jssg test -l tsx ./solana-compat-pilot.codemod.ts ./tests",
    "test:pipeline": "node --test ./tests/pipeline/*.test.mjs",
    "test:verbose": "npx codemod jssg test -l tsx ./solana-compat-pilot.codemod.ts ./tests -v",
    "validate": "npx codemod workflow validate -w workflow.yaml",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "audit": "npm audit --audit-level=moderate",
    "ci": "npm run typecheck && npm test && npm run fixtures:count && npm run validate && npm run audit",
    "migration-score": "node ./scripts/migration-score.mjs",
    "benchmark:pipeline": "node ./scripts/benchmark-pipeline.mjs",
    "case-study:replay": "node ./scripts/replay-case-study.mjs",
    "fixtures:count": "node ./scripts/count-fixtures.mjs",
    "registry:publish": "codemod publish ."
  },
  "devDependencies": {
    "@codemod.com/jssg-types": "1.6.0",
    "codemod": "1.9.0",
    "typescript": "6.0.3"
  }
}
